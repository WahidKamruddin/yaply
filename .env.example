VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
VITE_GIPHY_API_KEY=your-giphy-api-key

# Splitwise integration (optional). Register an app at https://secure.splitwise.com/apps/new
# to get client credentials. Leave blank to disable Splitwise features.
VITE_SPLITWISE_CLIENT_ID=
VITE_SPLITWISE_CLIENT_SECRET=

# Set to "true" to skip Supabase auth entirely during local development.
# Uses a hardcoded dev user (id: dev-user-00000000-..., email: dev@localhost).
# Never set this in production.
VITE_DEV_BYPASS_AUTH=false
